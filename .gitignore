# ==========================================
# Kotocord .gitignore
# 适用: vcpkg + Qt6 + CMake + MSVC 项目
# ==========================================

# ==========================================
# CMake 构建产物 (不纳入版本控制)
# ==========================================
build*/
cmake-build-*/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
Makefile
*.cmake
CMakeUserPresets.json
CMakeSettings.json

# ==========================================
# CMakePresets — 每人本地维护自己的配置
# CMakePresets.json.example 是模板 (提交)
# CMakePresets.json 是本地配置 (忽略)
# ==========================================
CMakePresets.json

# ==========================================
# 可执行文件输出目录
# ==========================================
bin/
out/

# ==========================================
# Visual Studio / MSVC
# ==========================================
.vs/
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.sln
*.suo
*.user
*.userosscache
*.sln.docstates
launch.vs.json
.editorconfig

# VS Code
.vscode/

# CLion
.idea/

# Qt Creator
*.pro.user
*.autosave
CMakeLists.txt.user

# ==========================================
# Qt 自动化生成 (由 AUTOMOC/AUTOUIC/AUTORCC 产生)
# ==========================================
*_autogen/
moc_*.cpp
moc_*.h
ui_*.h
qrc_*.cpp
*.moc

# ==========================================
# vcpkg (本地安装, 各自独立)
# ==========================================
vcpkg_installed/
vcpkg-manifest-install/
vcpkg-configuration.json
vcpkg.json

# ==========================================
# 第三方库文件 (体积巨大, 用户自行下载)
# ==========================================
third_party/**/*.dll
third_party/**/*.lib
third_party/**/*.a
third_party/**/*.so
third_party/**/*.dylib
third_party/**/*.exp
third_party/**/*.def
third_party/**/*.pdb
third_party/**/*.exe

# 保留头文件 (体积小, 便于 IDE 代码补全)
!third_party/**/*.h

# ==========================================
# 参考文件 (不提交)
# ==========================================
old_set/

# ==========================================
# 模型文件 (绝对不能上传, 体积几百MB)
# ==========================================
resources/model/
*.bin
*.wav
*.mp3

# ==========================================
# 操作系统缓存
# ==========================================
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
.DS_Store
.AppleDouble
.LSOverride
Desktop.ini
$RECYCLE.BIN/

# ==========================================
# 压缩包 (临时下载)
# ==========================================
*.zip
*.tar.gz
*.tar.xz
*.7z
*.rar

# 但保留这个例外:
!resources/**/*.zip
