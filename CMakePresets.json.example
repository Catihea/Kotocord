{
    "_comment": [
        "====================================================================",
        " CMakePresets.json 模板",
        " 复制为 CMakePresets.json 后按自己的环境修改。",
        "",
        " 关键变量:",
        "   USE_VCPKG = ON  → vcpkg 管理 Qt6 + whisper.cpp (需先执行 vcpkg install)",
        "   USE_VCPKG = OFF → 手动模式: 设置 CMAKE_PREFIX_PATH 指向 Qt 安装目录,",
        "                      whisper.cpp 从 third_party/whisper/ 加载",
        "",
        " 常见 Qt 路径参考:",
        "   C:/Qt/6.5.0/msvc2019_64         ← Qt 6.5 MSVC (C盘默认)",
        "   C:/Qt/6.9.0/msvc2022_64         ← Qt 6.9 MSVC",
        "   H:/Software/Qt/Qt6.9.3/6.9.3/msvc2022_64  ← Qt 6.9 装在H盘 (旧电脑实录)",
        "   D:/Qt/6.x.x/mingw_64            ← Qt MinGW 装在D盘",
        "",
        " vcpkg 路径参考:",
        "   C:/vcpkg/scripts/buildsystems/vcpkg.cmake  ← vcpkg 默认路径",
        "   D:/vcpkg/scripts/buildsystems/vcpkg.cmake  ← vcpkg 装在D盘 (C盘空间不足)",
        "===================================================================="
    ],
    "version": 3,
    "configurePresets": [
        {
            "name": "msvc-debug-vcpkg",
            "displayName": "Windows x64 Debug (vcpkg)",
            "description": "vcpkg 管理模式: Qt6 + whisper-cpp 全部由 vcpkg 提供。首次使用需执行 vcpkg install。",
            "generator": "Visual Studio 17 2022",
            "binaryDir": "${sourceDir}/build/msvc-debug-vcpkg",
            "toolchainFile": "C:/vcpkg/scripts/buildsystems/vcpkg.cmake",
            "cacheVariables": {
                "USE_VCPKG": "ON"
            }
        },
        {
            "name": "msvc-release-vcpkg",
            "displayName": "Windows x64 Release (vcpkg)",
            "description": "vcpkg 管理模式 — Release 优化构建",
            "generator": "Visual Studio 17 2022",
            "binaryDir": "${sourceDir}/build/msvc-release-vcpkg",
            "toolchainFile": "C:/vcpkg/scripts/buildsystems/vcpkg.cmake",
            "cacheVariables": {
                "USE_VCPKG": "ON"
            }
        },
        {
            "name": "msvc-debug-manual",
            "displayName": "Windows x64 Debug (手动 Qt, 无 vcpkg)",
            "description": "手动管理模式: 使用官方 Qt 安装器, whisper.cpp 从 third_party/whisper/ 加载。",
            "generator": "Visual Studio 17 2022",
            "binaryDir": "${sourceDir}/build/msvc-debug-manual",
            "cacheVariables": {
                "USE_VCPKG": "OFF",
                "CMAKE_PREFIX_PATH": "C:/Qt/6.5.0/msvc2019_64"
            }
        },
        {
            "name": "msvc-release-manual",
            "displayName": "Windows x64 Release (手动 Qt, 无 vcpkg)",
            "description": "手动管理模式 — Release 优化构建",
            "generator": "Visual Studio 17 2022",
            "binaryDir": "${sourceDir}/build/msvc-release-manual",
            "cacheVariables": {
                "USE_VCPKG": "OFF",
                "CMAKE_PREFIX_PATH": "C:/Qt/6.5.0/msvc2019_64"
            }
        },
        {
            "name": "mingw-debug-manual",
            "displayName": "Windows x64 Debug (MinGW + 手动 Qt)",
            "description": "使用 MinGW 编译器 + 官方 Qt MinGW 版本。不需要 vcpkg。",
            "generator": "MinGW Makefiles",
            "binaryDir": "${sourceDir}/build/mingw-debug-manual",
            "cacheVariables": {
                "USE_VCPKG": "OFF",
                "CMAKE_PREFIX_PATH": "C:/Qt/6.5.0/mingw_64",
                "CMAKE_BUILD_TYPE": "Debug"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug-vcpkg",
            "configurePreset": "msvc-debug-vcpkg",
            "configuration": "Debug"
        },
        {
            "name": "release-vcpkg",
            "configurePreset": "msvc-release-vcpkg",
            "configuration": "Release"
        },
        {
            "name": "debug-manual",
            "configurePreset": "msvc-debug-manual",
            "configuration": "Debug"
        },
        {
            "name": "release-manual",
            "configurePreset": "msvc-release-manual",
            "configuration": "Release"
        }
    ]
}
